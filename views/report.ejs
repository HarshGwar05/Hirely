<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <title>AI Report</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<div class="dashboard">

<div class="report-hero">

    <div>

        <h1><%= result.original_name %></h1>

        <p class="report-subtitle">

            AI Candidate Evaluation Report

        </p>

    </div>

    <%
let scoreColor = "score-red";

if(result.decision === "STRONG_MATCH"){

    scoreColor = "score-green";

}
else if(result.decision === "GOOD_MATCH"){

    scoreColor = "score-blue";

}
else if(result.decision === "REVIEW"){

    scoreColor = "score-orange";

}
%>

<div class="score-circle <%= scoreColor %>">

    <span>

        <%= Number(result.score).toFixed(1) %>

    </span>

    <small>/10</small>

</div>

</div>

<div class="metrics-grid">

    <div class="metric-card">

        <h4>Decision</h4>

        <span class="decision <%= result.decision === 'STRONG_MATCH'
            ? 'strong-match'
            : result.decision === 'GOOD_MATCH'
            ? 'good-match'
            : result.decision === 'REVIEW'
            ? 'review'
            : 'reject'
        %>">

            <%= result.decision.replace("_"," ") %>

        </span>

    </div>

    <div class="metric-card">

        <h4>Confidence</h4>

        <div class="confidence-bar">

            <div
                class="confidence-fill"
                style="width:<%= result.confidence %>%"
            ></div>

        </div>

        <p><%= result.confidence %>%</p>

    </div>

    <div class="metric-card">

        <h4>Requirement Coverage</h4>

        <div class="confidence-bar">

            <div
                class="confidence-fill"
                style="width:<%= result.requirement_coverage %>%"
            ></div>

        </div>

        <p><%= result.requirement_coverage %>%</p>

    </div>

</div>
<hr>
<div class="section-card">

    <h2>Summary</h2>

    <p>

        <%= result.analysis_json.summary %>

    </p>
</div>

<hr>



<div class="three-column-grid">

    <div class="section-card">

        <h2>Strengths</h2>

        <% result.analysis_json.strengths.forEach(item=>{ %>

            <div class="feature success">

                ✓ <%= item %>

            </div>

        <% }) %>

    </div>

    <div class="section-card">

        <h2>Weaknesses</h2>

        <% result.analysis_json.weaknesses.forEach(item=>{ %>

            <div class="feature warning">

                ⚠ <%= item %>

            </div>

        <% }) %>

    </div>

    <div class="section-card">

        <h2>Missing Skills</h2>

        <% result.analysis_json.missing_skills.forEach(item=>{ %>

            <div class="feature danger">

                ✖ <%= item %>

            </div>

        <% }) %>

    </div>

</div>

<div class="section-card">

    <h2>Requirement Evidence</h2>

    <table class="evidence-table">

        <thead>

            <tr>

                <th>Requirement</th>

                <th>Resume Evidence</th>

            </tr>

        </thead>

        <tbody>

        <% result.analysis_json.evidence.forEach(item=>{ %>

            <tr>

                <td>

                    <strong>

                        <%= item.requirement %>

                    </strong>

                </td>

                <td>

                    <%= item.evidence %>

                </td>

            </tr>

        <% }) %>

        </tbody>

    </table>

</div>


<div class="section-card">

<h2>Interview Questions</h2>

<div class="question-grid">

<% result.analysis_json.interview_questions.forEach((item,index)=>{ %>

<div class="question-card">

<div class="question-number">

<%= index+1 %>

</div>

<p>

<%= item %>

</p>

</div>

<% }) %>

</div>

</div>

<div class="section-card">

<h2>Improvement Suggestions</h2>

<% result.analysis_json.improvement_suggestions.forEach(item=>{ %>

<div class="suggestion-card">

💡

<span>

<%= item %>

</span>

</div>

<% }) %>

</div>

<div class="back-container">

<a
href="javascript:history.back()"
class="back-btn"
>

← Back to Results

</a>

</div>

</div>

</body>

</html>
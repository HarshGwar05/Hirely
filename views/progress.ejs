<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <title>Screening Progress</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

    <div class="dashboard">

    <h1><%= screening.job_title %></h1>

    <hr>

    <h3>Status</h3>

    <p>
        <strong><%= screening.status %></strong>
    </p>

    <p>
        Total Resumes :
        <strong><%= screening.total_resumes %></strong>
    </p>

    <p>
        Completed :
        <strong><%= screening.completed_resumes %></strong>
    </p>

    <p>
        Failed :
        <strong><%= screening.failed_resumes %></strong>
    </p>

    <hr>

    <h2>Resumes</h2>

    <% resumes.forEach(resume => { %>

        <div class="resume-item">

            <span class="resume-name">

                <%= resume.original_name %>

            </span>

            <span class="resume-status">

                <%= resume.processing_status %>

            </span>

        </div>

    <% }) %>

</div>

<script>

    setInterval(() => {

        window.location.reload();

    }, 3000);

</script>

</body>

</html>
<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <title>Screening Progress</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

    <div class="dashboard">

    <div class="progress-hero">

    <div>

        <h1><%= screening.job_title %></h1>

        <p class="progress-subtitle">

            AI Resume Screening Progress

        </p>

    </div>

    <div class="progress-status-badge">

        <span id="screeningStatus">

            <%= screening.status %>

        </span>

    </div>

</div>

    <div class="progress-card">

    <div class="progress-container">

        <div class="progress-bar">

            <div
                id="completedFill"
                class="progress-fill completed-fill"
            ></div>

            <div
                id="failedFill"
                class="progress-fill failed-fill"
            ></div>

        </div>

        <div id="progressText">

            0%

        </div>

    </div>

    <div class="progress-stats">

        <div class="mini-stat">

            <h4>Total</h4>

            <p>

                <%= screening.total_resumes %>

            </p>

        </div>

        <div class="mini-stat">

            <h4>Completed</h4>

            <p id="completedCount">

                <%= screening.completed_resumes %>

            </p>

        </div>

        <div class="mini-stat">

            <h4>Failed</h4>

            <p id="failedCount">

                <%= screening.failed_resumes %>

            </p>

        </div>

    </div>

</div>

<hr>

   

<% if (screening.status === "COMPLETED") { %>

    <div class="screening-complete-box">

        <h2>

            ✓ Screening Completed

        </h2>

        <p>
            <%= screening.completed_resumes %> completed •
            <%= screening.failed_resumes %> failed
        </p>

        <a
            class="view-results-btn"
            href="/screenings/<%= screening.screening_id %>/results"
        >

            View Results →

        </a>

    </div>

    <hr>

<% } %>

<h2 class="section-title">

Resume Processing

</h2>

    <% resumes.forEach(resume => { %>

        <div class="progress-resume-card">

    <div>

        <strong>

            <%= resume.original_name %>

        </strong>

    </div>

    <span class="progress-badge <%= resume.processing_status.toLowerCase() %>">

        <%= resume.processing_status %>

    </span>

</div>

    <% }) %>

</div>

    <script>
        const screeningId ="<%= screening.screening_id %>";
    </script>

    <script src="/js/screeningProgress.js"></script>

</body>

</html>
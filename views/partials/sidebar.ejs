<div class="sidebar">

    <div class="sidebar-header">

        <h2>Hirely</h2>

        <p>AI Resume Screener</p>

    </div>

    <div class="selected-count">

        Selected :
        <strong id="selectedCount">0</strong>

    </div>

    <input
        type="text"
        id="searchResume"
        placeholder="Search resumes..."
        class="search-box"
    >

    <div class="resume-list">

        <% resumes.filter(r => !r.is_archived).forEach(resume => { %>

        <div class="resume-item">

            <input
                class="resume-checkbox"
                type="checkbox"
                value="<%= resume.resume_id %>"
            >

            <span class="status <%= resume.status.toLowerCase() %>"></span>

            <div class="resume-info">

                <span
                    class="resume-name"
                    title="<%= resume.original_name %>"
                >
                    <%= resume.original_name %>
                </span>

                <div class="resume-date">

                    <%= new Date(resume.uploaded_at).toLocaleDateString() %>

                </div>

            </div>

            <form
                action="/resumes/<%= resume.resume_id %>?_method=DELETE"
                method="POST"
                class="delete-form"
            >

                <button
                    type="submit"
                    class="delete-btn"
                    title="Delete"
                >

                    🗑

                </button>

            </form>

        </div>

        <% }) %>

    </div>

    <div
        class="archived"
        id="archiveToggle"
    >

        ▶ Archived (<%= resumes.filter(r => r.is_archived).length %>)

    </div>

    <div
        id="archiveList"
        class="archived-list"
        style="display:none;"
    >

        <% resumes.filter(r => r.is_archived).forEach(resume => { %>

        <div class="resume-item">

            <span class="status <%= resume.status.toLowerCase() %>"></span>

            <div class="resume-info">

                <span class="resume-name">

                    <%= resume.original_name %>

                </span>

                <div class="resume-date">

                    <%= new Date(resume.uploaded_at).toLocaleDateString() %>

                </div>

            </div>

            <form
                action="/resumes/<%= resume.resume_id %>/restore"
                method="POST"
            >

                <button
                    class="restore-btn"
                    type="submit"
                >

                    Restore

                </button>

            </form>

        </div>

        <% }) %>

    </div>

    <form
        class="upload-form"
        action="/resumes/upload"
        method="POST"
        enctype="multipart/form-data"
    >

        <input
            hidden
            id="resumeInput"
            type="file"
            name="resumes"
            multiple
            accept=".pdf"
        >

        <button
            class="upload-btn"
            type="button"
            onclick="document.getElementById('resumeInput').click()"
        >

            + Upload Resume

        </button>

    </form>

    <a
        href="/history"
        class="history-btn"
    >

        Screening History

    </a>

</div>
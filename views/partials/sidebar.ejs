<div class="sidebar">

    <h2>Resume Library</h2>

    <div class="selected-count">
        Selected : <strong id="selectedCount">0</strong>
    </div>

    <input
        type="text"
        placeholder="🔍 Search Resume..."
        class="search-box"
    >

    <div class="resume-list">

        <% resumes.filter(r => !r.is_archived).forEach(resume => { %>

            <div class="resume-item">

                <input
                    class="resume-checkbox"
                    type="checkbox"
                    value="<%= resume.resume_id %>"
                >

                <span class="status <%= resume.status.toLowerCase() %>"></span>

                <div class="resume-info">

                    <span
                        class="resume-name"
                        title="<%= resume.original_name %>"
                    >
                        <%= resume.original_name %>
                    </span>

                    <div style="font-size:11px;color:#777;">
                        <%= new Date(resume.uploaded_at).toLocaleDateString() %>
                    </div>

                </div>

                <form
                    action="/resumes/<%= resume.resume_id %>?_method=DELETE"
                    method="POST"
                    class="delete-form"
                >
                    <button
                        type="submit"
                        class="delete-btn"
                        title="Delete (or Archive if used in a screening)"
                    >
                        🗑
                    </button>
                </form>

            </div>

        <% }) %>

    </div>

    <div
        class="archived"
        id="archiveToggle"
    >
        ▶ Archived (<%= resumes.filter(r => r.is_archived).length %>)
    </div>

    <div
        class="archived-list"
        id="archiveList"
        style="display:none;"
    >

        <% resumes.filter(r => r.is_archived).forEach(resume => { %>

            <div class="resume-item">

                <span class="status <%= resume.status.toLowerCase() %>"></span>

                <div class="resume-info">

                    <span
                        class="resume-name"
                        title="<%= resume.original_name %>"
                    >
                        <%= resume.original_name %>
                    </span>

                    <div style="font-size:11px;color:#777;">
                        <%= new Date(resume.uploaded_at).toLocaleDateString() %>
                    </div>

                </div>

            </div>

        <% }) %>

    </div>

    <form
        class="upload-form"
        action="/resumes/upload"
        method="POST"
        enctype="multipart/form-data"
    >

        <input
            type="file"
            id="resumeInput"
            name="resumes"
            accept=".pdf"
            multiple
            hidden
        >

        <button
            type="button"
            class="upload-btn"
            onclick="document.getElementById('resumeInput').click()"
        >
            + Upload Resume
        </button>

    </form>

    <button
        id="startScreeningBtn"
        class="screening-btn"
        disabled
    >
        Start Screening
    </button>

</div>
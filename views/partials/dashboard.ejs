<div class="dashboard">

    <h2>Start New Screening</h2>

    <div class="form-group">

        <label>Job Title</label>

        <input
            type="text"
            id="jobTitle"
            placeholder="e.g. Backend Developer"
        >

    </div>

    <div class="form-group">

        <label>Job Description</label>

        <textarea
            id="jobDescription"
            rows="12"
            placeholder="Paste the job description here..."
        ></textarea>

    </div>

    <p>

        Selected Resumes :

        <strong id="selectedResumeCount">

            0

        </strong>

    </p>

    <button
        id="analyseBtn"
        disabled
    >
        Start Analysis
    </button>

</div>